print("\n" + "=" * 60)
print("ÉTAPE 12 : EXEMPLE D'UTILISATION EN PRODUCTION")
print("=" * 60)

def predict_fraud(transaction: pd.DataFrame,
                  model_path='best_fraud_model.pkl',
                  scaler_path='scaler.pkl',
                  threshold_path='best_threshold.npy') -> dict:
    """
    Prédit si une transaction est frauduleuse.

    Parameters
    ----------
    transaction : pd.DataFrame
        DataFrame avec les colonnes V1-V28, Amount, Time

    Returns
    -------
    dict : {'is_fraud': bool, 'probability': float, 'risk_level': str}
    """
    loaded_model = joblib.load(model_path)
    loaded_scaler = joblib.load(scaler_path)
    threshold = np.load(threshold_path)[0]

    # Pré-traitement
    transaction = transaction.copy()
    transaction['Amount_log'] = np.log1p(transaction['Amount'])
    transaction['Hour'] = (transaction['Time'] / 3600) % 24
    transaction['Is_night'] = ((transaction['Hour'] >= 22) | (transaction['Hour'] <= 6)).astype(int)
    transaction.drop(['Amount', 'Time'], axis=1, inplace=True)
    transaction[['Amount_log', 'Hour']] = loaded_scaler.transform(
        transaction[['Amount_log', 'Hour']]
    )

    # Prédiction
    proba = loaded_model.predict_proba(transaction)[:, 1][0]
    is_fraud = proba >= threshold

    risk_level = "ÉLEVÉ" if proba >= 0.8 else "MOYEN" if proba >= 0.5 else "FAIBLE"

    return {
        'is_fraud': bool(is_fraud),
        'probability': round(float(proba), 4),
        'risk_level': risk_level,
        'threshold_used': round(float(threshold), 2)
    }


# Test sur quelques transactions
print("\nTest sur des transactions de l'ensemble de test :")
sample_indices = [0, 1, 2]
for idx in sample_indices:
    sample_tx = X_test.iloc[[idx]].copy()
