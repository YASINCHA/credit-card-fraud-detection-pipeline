"""
=============================================================
PROJET COMPLET : DÉTECTION DE FRAUDE SUR CARTES DE CRÉDIT
=============================================================
Dataset : creditcard.csv (Kaggle - whenamancodes/fraud-detection)
Objectif : Classer les transactions en fraude (1) ou normale (0)
=============================================================
"""

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import warnings
warnings.filterwarnings('ignore')

from sklearn.preprocessing import StandardScaler
from sklearn.model_selection import train_test_split, StratifiedKFold, cross_val_score
from sklearn.metrics import (
    classification_report, confusion_matrix, roc_auc_score,
    roc_curve, precision_recall_curve, average_precision_score,
    f1_score, precision_score, recall_score
)
from sklearn.linear_model import LogisticRegression
from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier
from sklearn.tree import DecisionTreeClassifier
from imblearn.over_sampling import SMOTE
from imblearn.under_sampling import RandomUnderSampler
from imblearn.pipeline import Pipeline as ImbPipeline
import xgboost as xgb
import joblib


# ============================================================
# ÉTAPE 1 : CHARGEMENT DES DONNÉES
# ============================================================

df = pd.read_csv('/kaggle/input/datasets/whenamancodes/fraud-detection/creditcard.csv')

print("=" * 60)
print("ÉTAPE 1 : CHARGEMENT DES DONNÉES")
print("=" * 60)
print(f"Shape : {df.shape}")
print(f"\nAperçu :\n{df.head()}")
print(f"\nInfos :\n{df.info()}")
print(f"\nDescription statistique :\n{df.describe()}")


# ============================================================
# ÉTAPE 2 : QUALITÉ DES DONNÉES
# ============================================================

print("\n" + "=" * 60)
print("ÉTAPE 2 : QUALITÉ DES DONNÉES")
print("=" * 60)

print(f"\nValeurs manquantes :\n{df.isnull().sum()}")

duplicates = df.duplicated().sum()
print(f"\nDoublons : {duplicates}")
if duplicates > 0:
    df = df.drop_duplicates()
    print(f"Doublons supprimés. Nouvelle shape : {df.shape}")


# ============================================================
# ÉTAPE 3 : ANALYSE DE LA VARIABLE CIBLE
# ============================================================

print("\n" + "=" * 60)
print("ÉTAPE 3 : ANALYSE DE LA VARIABLE CIBLE")
print("=" * 60)

print(f"\nDistribution des classes :\n{df['Class'].value_counts()}")
print(f"\nRatio :\n{df['Class'].value_counts(normalize=True)}")

plt.figure(figsize=(6, 4))
sns.countplot(x='Class', data=df, palette=['#3498db', '#e74c3c'])
plt.title("Distribution des classes (0=Normal, 1=Fraude)")
plt.savefig("class_distribution.png", dpi=150, bbox_inches='tight')
plt.show()


# ============================================================
# ÉTAPE 4 : PRÉ-TRAITEMENT COMPLET
# ============================================================

print("\n" + "=" * 60)
print("ÉTAPE 4 : PRÉ-TRAITEMENT COMPLET")
print("=" * 60)

# --- 4.1 Transformation logarithmique de Amount ---
print("\n[4.1] Log transformation de Amount...")
df['Amount_log'] = np.log1p(df['Amount'])
df.drop('Amount', axis=1, inplace=True)

# --- 4.2 Ingénierie temporelle ---
print("[4.2] Feature engineering sur Time...")
df['Hour'] = (df['Time'] / 3600) % 24
df['Is_night'] = ((df['Hour'] >= 22) | (df['Hour'] <= 6)).astype(int)
df.drop('Time', axis=1, inplace=True)

# --- 4.3 Scaling ---
print("[4.3] Scaling des features Amount_log et Hour...")
scaler = StandardScaler()
df[['Amount_log', 'Hour']] = scaler.fit_transform(df[['Amount_log', 'Hour']])

# Sauvegarder le scaler pour la production
joblib.dump(scaler, 'scaler.pkl')

# --- 4.4 Visualisation post-preprocessing ---
fraud = df[df['Class'] == 1]
normal = df[df['Class'] == 0]

plt.figure(figsize=(10, 4))
sns.histplot(normal['Amount_log'], color='blue', label='Normal', kde=True, alpha=0.6)
sns.histplot(fraud['Amount_log'], color='red', label='Fraude', kde=True, alpha=0.6)
plt.legend()
plt.title("Distribution Amount_log : Fraude vs Normal")
plt.savefig("amount_distribution.png", dpi=150, bbox_inches='tight')
plt.show()

print(f"\nDataset après pré-traitement : {df.shape}")
print(f"Features : {list(df.columns)}")


# ============================================================
# ÉTAPE 5 : SÉPARATION FEATURES / TARGET
# ============================================================

X = df.drop('Class', axis=1)
y = df['Class']

print(f"\n[5] X shape: {X.shape}, y shape: {y.shape}")
print(f"Proportion de fraudes : {y.mean():.4%}")


# ============================================================
# ÉTAPE 6 : COMPARAISON DES SPLITS
# ============================================================

print("\n" + "=" * 60)
print("ÉTAPE 6 : COMPARAISON DES STRATÉGIES DE SPLIT")
print("=" * 60)

"""
On compare 3 stratégies de split pour choisir la meilleure
avant l'entraînement final du modèle. Le critère principal
est le AUC-PR (Average Precision) car le dataset est déséquilibré.
"""

splits_config = [
    {"name": "70% Train / 30% Test", "test_size": 0.30},
    {"name": "80% Train / 20% Test", "test_size": 0.20},
    {"name": "85% Train / 15% Test", "test_size": 0.15},
]

# Modèle de référence léger pour la comparaison
ref_model = LogisticRegression(max_iter=1000, random_state=42)

split_results = []

for config in splits_config:
    X_tr, X_te, y_tr, y_te = train_test_split(
        X, y,
        test_size=config["test_size"],
        stratify=y,
        random_state=42
    )

    # Application SMOTE sur train uniquement
    smote = SMOTE(random_state=42)
    X_tr_res, y_tr_res = smote.fit_resample(X_tr, y_tr)

    # Entraînement
    ref_model.fit(X_tr_res, y_tr_res)

    # Évaluation
    y_pred = ref_model.predict(X_te)
    y_proba = ref_model.predict_proba(X_te)[:, 1]

    roc_auc = roc_auc_score(y_te, y_proba)
    ap = average_precision_score(y_te, y_proba)
    f1 = f1_score(y_te, y_pred)
    precision = precision_score(y_te, y_pred)
    recall = recall_score(y_te, y_pred)

    # Cross-validation
    cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)
    cv_scores = cross_val_score(ref_model, X_tr_res, y_tr_res, cv=cv, scoring='roc_auc')

    split_results.append({
        "Split": config["name"],
        "Train size": len(X_tr),
        "Test size": len(X_te),
        "Fraud in test": y_te.sum(),
        "ROC-AUC": round(roc_auc, 4),
        "Avg Precision": round(ap, 4),
        "F1 Score": round(f1, 4),
        "Precision": round(precision, 4),
        "Recall": round(recall, 4),
        "CV AUC Mean": round(cv_scores.mean(), 4),
        "CV AUC Std": round(cv_scores.std(), 4),
    })

    print(f"\n--- {config['name']} ---")
    print(f"  Train: {len(X_tr)}, Test: {len(X_te)}, Fraudes test: {y_te.sum()}")
    print(f"  ROC-AUC: {roc_auc:.4f} | Avg Precision: {ap:.4f} | F1: {f1:.4f}")
    print(f"  CV AUC: {cv_scores.mean():.4f} ± {cv_scores.std():.4f}")

# Afficher le tableau comparatif
results_df = pd.DataFrame(split_results)
print("\n\n=== TABLEAU COMPARATIF DES SPLITS ===")
print(results_df.to_string(index=False))

# Déterminer le meilleur split selon Avg Precision
best_split_idx = results_df['Avg Precision'].idxmax()
best_split = results_df.loc[best_split_idx, 'Split']
print(f"\n>>> MEILLEUR SPLIT : {best_split} (Avg Precision = {results_df.loc[best_split_idx, 'Avg Precision']})")

# Visualisation des résultats
fig, axes = plt.subplots(1, 3, figsize=(15, 5))
metrics = ['ROC-AUC', 'Avg Precision', 'F1 Score']
colors = ['#3498db', '#2ecc71', '#e74c3c']

for ax, metric, color in zip(axes, metrics, colors):
    bars = ax.bar(
        [r['Split'].replace(' / ', '\n') for r in split_results],
        [r[metric] for r in split_results],
        color=color, alpha=0.8
    )
    ax.set_title(metric, fontsize=13, fontweight='bold')
    ax.set_ylim(0, 1)
    ax.set_ylabel("Score")
    for bar, val in zip(bars, [r[metric] for r in split_results]):
        ax.text(bar.get_x() + bar.get_width() / 2, bar.get_height() + 0.01,
                f'{val:.4f}', ha='center', va='bottom', fontsize=10)

plt.suptitle("Comparaison des stratégies de Split", fontsize=14, fontweight='bold')
plt.tight_layout()
plt.savefig("split_comparison.png", dpi=150, bbox_inches='tight')
plt.show()

"""
CONCLUSION SPLIT :
- 80/20 stratifié est généralement le meilleur compromis
  car il offre suffisamment de données d'entraînement tout
  en gardant un ensemble de test représentatif.
- Le split stratifié garantit la proportion de fraudes
  dans chaque ensemble.
"""


